# Optional: override the PostgREST API base URL.
# Defaults to https://api.skrebeyko.ru if unset.
VITE_POSTGREST_URL=

# Optional: override the auth service URL.
# Defaults to https://auth.skrebeyko.ru if unset.
VITE_AUTH_URL=

# Required for /admin access (NB-RESTORE Phase 1).
# Comma-separated list of profiles.id UUIDs allowed to enter /admin.
# Defence-in-depth on top of role==='admin' check.
# Prod admin: Olga = 85dbefda-ba8f-4c60-9f22-b3a7acd45b21
VITE_MEETINGS_ADMIN_USER_IDS=
